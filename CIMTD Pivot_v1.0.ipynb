   "source": [
    "\"\"\"\n",
    "cimt_pivot.py  —  Interactive pivot table for CIMT trade data\n",
    "=============================================================\n",
    "Run this in VS Code as a Jupyter notebook (.ipynb) or as cells in an\n",
    "interactive Python session.\n",
    "\n",
    "Requirements (one-time install):\n",
    "    pip install pivottablejs pandas\n",
    "\n",
    "HOW TO USE\n",
    "----------\n",
    "1. Run Cell 1 to load all data from your CIMTD folder.\n",
    "2. Run Cell 2, pick your commodity, run it — pivot appears below.\n",
    "3. In the pivot UI:\n",
    "   - Drag \"Country\" or \"HS6\" into the row area to slice by country/code\n",
    "   - Drag \"Year\" or \"Month\" into columns as needed\n",
    "   - Use the dropdown at top-left to switch aggregation (Sum, Count, etc.)\n",
    "   - Click column/row labels to filter values\n",
    "\"\"\"\n",
    "\n",
    "# %%\n",
    "# ─────────────────────────────────────────────────────────────────────\n",
    "# CELL 1 — Load all data (run once per session)\n",
    "# ─────────────────────────────────────────────────────────────────────\n",
    "from pathlib import Path\n",
    "import zipfile\n",
    "import calendar\n",
    "import pandas as pd\n",
    "from pivottablejs import pivot_ui\n",
    "\n",
    "CIMTD = Path(r\"C:\\Users\\ahmed\\OneDrive\\Desktop\\Python\\CIMTD\")\n",
    "\n",
    "MONTH_NUM  = {calendar.month_abbr[m]: m for m in range(1, 13)}\n",
    "MONTH_ABBR = [calendar.month_abbr[m] for m in range(1, 13)]\n",
    "\n",
    "# ── Commodity -> HS6 codes (plain integers, no dots)\n",
    "COMMODITY_CONFIG = {\n",
    "    \"Amber Durum\":      [100111, 100119],\n",
    "    \"Wheat (Ex-Durum)\": [100191, 100199],\n",
    "    \"Canola\":           [120510, 120590],\n",
    "    \"Soybeans\":         [120110, 120190],\n",
    "    \"Corn\":             [100510, 100590],\n",
    "    \"Barley\":           [100310, 100390],\n",
    "    \"Red Lentils\":      [71340,  71341],\n",
    "    \"Yellow Peas\":      [71310,  71390],\n",
    "}\n",
    "\n",
    "def parse_country_lookup(zf):\n",
    "    \"\"\"\n",
    "    Parses ODPF_6_CtyDesc.TXT from the zip.\n",
    "    Line format: CC NNN     DDDDDD DDDDDD English Name        French Name ...\n",
    "    English name starts at position 25.\n",
    "    \"\"\"\n",
    "    fname = next((n for n in zf.namelist() if \"CtyDesc\" in n), None)\n",
    "    if not fname:\n",
    "        return {}\n",
    "    mapping = {}\n",
    "    with zf.open(fname) as f:\n",
    "        for raw in f:\n",
    "            line = raw.decode(\"latin-1\")\n",
    "            if len(line) < 30:\n",
    "                continue\n",
    "            code    = line[:2].strip()\n",
    "            # English name starts at char 25; ends before the French section\n",
    "            # (separated by 2+ spaces). Use regex for robustness.\n",
    "            m = re.match(r'^(\\w{2})\\s+\\d+\\s+\\d{6}\\s+\\d{6}\\s+(.+?)(?:\\s{2,}|\\s*$)', line)\n",
    "            if m:\n",
    "                code    = m.group(1).strip()\n",
    "                english = m.group(2).strip()\n",
    "                if code and english:\n",
    "                    mapping[code] = english\n",
    "    return mapping\n",
    "\n",
    "def find_hs6_csv(zf, trade_type):\n",
    "    prefix = \"ODPFN015\" if trade_type == \"Import\" else \"ODPFN019\"\n",
    "    match  = next(\n",
    "        (n for n in zf.namelist()\n",
    "         if Path(n).name.startswith(prefix) and n.endswith(\".csv\")), None\n",
    "    )\n",
    "    if not match:\n",
    "        skip = {\"ODPFN021\",\"ODPFN022\",\"ODPFN017\",\"ODPFN014\"}\n",
    "        match = next(\n",
    "            (n for n in zf.namelist()\n",
    "             if n.endswith(\".csv\") and not any(s in Path(n).name for s in skip)), None\n",
    "        )\n",
    "    return match\n",
    "\n",
    "def read_zip(zip_path):\n",
    "    name = zip_path.name.upper()\n",
    "    trade_type = \"Import\" if \"IMP\" in name else \"Export\"\n",
    "\n",
    "    with zipfile.ZipFile(zip_path) as zf:\n",
    "        country_map = parse_country_lookup(zf)\n",
    "        csv_path    = find_hs6_csv(zf, trade_type)\n",
    "        if not csv_path:\n",
    "            return None\n",
    "        with zf.open(csv_path) as f:\n",
    "            df = pd.read_csv(f, encoding=\"latin-1\", low_memory=False)\n",
    "\n",
    "    # Normalise column names\n",
    "    rename = {}\n",
    "    for col in df.columns:\n",
    "        c = col.lower()\n",
    "        if \"yearmonth\" in c or \"annee\" in c:\n",
    "            rename[col] = \"YearMonth\"\n",
    "        elif col.strip() == \"HS6\":\n",
    "            rename[col] = \"HS6\"\n",
    "        elif \"country\" in c or \"pays\" in c:\n",
    "            rename[col] = \"CountryCode\"\n",
    "        elif \"value\" in c or \"valeur\" in c:\n",
    "            rename[col] = \"ValueCAD\"\n",
    "        elif \"quantity\" in c or \"quantit\" in c:\n",
    "            rename[col] = \"Quantity\"\n",
    "        elif \"unit\" in c:\n",
    "            rename[col] = \"UOM\"\n",
    "    df = df.rename(columns=rename)\n",
    "\n",
    "    ym        = df[\"YearMonth\"].astype(int).astype(str).str.zfill(6)\n",
    "    df[\"Year\"]  = ym.str[:4].astype(int)\n",
    "    df[\"Month\"] = ym.str[4:6].astype(int)\n",
    "    df[\"HS6\"]   = pd.to_numeric(df[\"HS6\"], errors=\"coerce\").astype(\"Int64\")\n",
    "    df[\"Country\"] = df[\"CountryCode\"].map(country_map).fillna(df[\"CountryCode\"])\n",
    "\n",
    "    # Per-row UOM conversion -> KMT\n",
    "    df[\"Quantity\"] = pd.to_numeric(df[\"Quantity\"], errors=\"coerce\").fillna(0)\n",
    "    if \"UOM\" in df.columns:\n",
    "        uom = df[\"UOM\"].astype(str).str.strip().str.upper()\n",
    "        df[\"KMT\"] = float(\"nan\")\n",
    "        df.loc[uom.isin([\"KGM\",\"KGE\"]), \"KMT\"] = (\n",
    "            df.loc[uom.isin([\"KGM\",\"KGE\"]), \"Quantity\"] / 1_000_000\n",
    "        )\n",
    "        df.loc[uom == \"TNE\", \"KMT\"] = df.loc[uom == \"TNE\", \"Quantity\"] / 1_000\n",
    "        df[\"KMT\"] = pd.to_numeric(df[\"KMT\"], errors=\"coerce\")\n",
    "    else:\n",
    "        df[\"KMT\"] = df[\"Quantity\"] / 1_000\n",
    "\n",
    "    df[\"ValueCAD\"]  = pd.to_numeric(df[\"ValueCAD\"], errors=\"coerce\").fillna(0)\n",
    "    df[\"TradeType\"] = trade_type\n",
    "\n",
    "    # ── Aggregate to country level (imports have province x state rows per country)\n",
    "    df = df.dropna(subset=[\"KMT\"])\n",
    "    df = (\n",
    "        df.groupby([\"Year\",\"Month\",\"TradeType\",\"HS6\",\"Country\"], as_index=False)\n",
    "        .agg({\"KMT\": \"sum\", \"ValueCAD\": \"sum\"})\n",
    "    )\n",
    "    return df[[\"Year\",\"Month\",\"TradeType\",\"HS6\",\"Country\",\"KMT\",\"ValueCAD\"]]\n",
    "\n",
    "# ── Load all zips\n",
    "print(\"Loading all CIMT zips from\", CIMTD)\n",
    "frames = []\n",
    "for z in sorted(CIMTD.glob(\"CIMT-CICM_*.zip\")):\n",
    "    print(f\"  {z.name}\", end=\"  \")\n",
    "    try:\n",
    "        result = read_zip(z)\n",
    "        if result is not None:\n",
    "            frames.append(result)\n",
    "            print(f\"{len(result):,} rows\")\n",
    "        else:\n",
    "            print(\"skipped (no HS6 CSV found)\")\n",
    "    except Exception as e:\n",
    "        print(f\"ERROR: {e}\")\n",
    "\n",
    "df_all = pd.concat(frames, ignore_index=True)\n",
    "df_all = df_all.drop_duplicates(subset=[\"Year\",\"Month\",\"TradeType\",\"HS6\",\"Country\"])\n",
    "df_all = df_all.dropna(subset=[\"KMT\"])   # drop non-weight rows (NMB etc.)\n",
    "\n",
    "print(f\"\\nReady: {len(df_all):,} rows | \"\n",
    "      f\"Years {df_all['Year'].min()}-{df_all['Year'].max()}\")\n",
    "\n",
    "# %%\n",
    "# ─────────────────────────────────────────────────────────────────────\n",
    "# CELL 2 — Pick commodity + trade type, display interactive pivot\n",
    "# ─────────────────────────────────────────────────────────────────────\n",
    "#\n",
    "# Set these two variables, then run the cell.\n",
    "#\n",
    "COMMODITY  = \"Canola\"          # one of the keys in COMMODITY_CONFIG above\n",
    "TRADE_TYPE = \"Export\"          # \"Export\" or \"Import\"\n",
    "\n",
    "# ── Filter\n",
    "codes = COMMODITY_CONFIG[COMMODITY]\n",
    "df_c  = df_all[\n",
    "    (df_all[\"HS6\"].isin(codes)) &\n",
    "    (df_all[\"TradeType\"] == TRADE_TYPE)\n",
    "].copy()\n",
    "\n",
    "# ── Round KMT to 1 decimal for display\n",
    "df_c[\"KMT\"] = df_c[\"KMT\"].round(1)\n",
    "\n",
    "print(f\"{COMMODITY} | {TRADE_TYPE}s | {len(df_c):,} rows\")\n",
    "print(f\"Countries: {df_c['Country'].nunique()} | \"\n",
    "      f\"Years: {df_c['Year'].min()}-{df_c['Year'].max()}\")\n",
    "\n",
    "# ── Launch pivot UI\n",
    "# Default layout: Years (rows) x Month (cols), Sum of KMT\n",
    "# You can drag any field into rows/cols from the field list in the UI.\n",
    "pivot_ui(\n",
    "    df_c[[\"Year\",\"Month\",\"Country\",\"HS6\",\"KMT\"]],\n",
    "    rows=[\"Year\"],\n",
    "    cols=[\"Month\"],\n",
    "    vals=[\"KMT\"],\n",
    "    aggregatorName=\"Sum\",\n",
    "    rendererName=\"Table\",\n",
    "    unusedOrientationCutoff=0,   # always show unused fields at top\n",
    ")\n",
    "\n",
    "# %%\n",
    "# ─────────────────────────────────────────────────────────────────────\n",
    "# CELL 3 — Quick summary: top countries by volume (optional)\n",
    "# ─────────────────────────────────────────────────────────────────────\n",
    "TOP_N      = 10\n",
    "LAST_YEARS = 3\n",
    "\n",
    "max_yr      = df_c[\"Year\"].max()\n",
    "top_ctry    = (\n",
    "    df_c[df_c[\"Year\"] >= max_yr - LAST_YEARS + 1]\n",
    "    .groupby(\"Country\")[\"KMT\"]\n",
    "    .sum()\n",
    "    .nlargest(TOP_N)\n",
    "    .reset_index()\n",
    "    .rename(columns={\"KMT\": f\"KMT ({max_yr-LAST_YEARS+1}-{max_yr})\"})\n",
    ")\n",
    "top_ctry[f\"KMT ({max_yr-LAST_YEARS+1}-{max_yr})\"] = (\n",
    "    top_ctry[f\"KMT ({max_yr-LAST_YEARS+1}-{max_yr})\"].round(1)\n",
    ")\n",
    "\n",
    "print(f\"\\nTop {TOP_N} destinations — {COMMODITY} {TRADE_TYPE}s (last {LAST_YEARS} years)\\n\")\n",
    "print(top_ctry.to_string(index=False))"
   ]
  }
