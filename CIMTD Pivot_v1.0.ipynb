    "\"\"\"\n",
    "cimt_download.py\n",
    "================\n",
    "Downloads CIMT zip files from Statistics Canada's Open Government Portal\n",
    "into your local CIMTD folder.\n",
    "\n",
    "USAGE\n",
    "-----\n",
    "First run (historical):\n",
    "    - Run the whole script as-is.\n",
    "    - Block A downloads 2012-2022 (static, never changes).\n",
    "    - Block B downloads the latest year files.\n",
    "\n",
    "Subsequent monthly runs:\n",
    "    - Comment out the line: download_block_a()\n",
    "    - Only Block B runs, fetching the latest monthly update files.\n",
    "\"\"\"\n",
    "\n",
    "import os\n",
    "import sys\n",
    "import time\n",
    "import requests\n",
    "from pathlib import Path\n",
    "\n",
    "# ── Output folder\n",
    "SAVE_DIR = Path(r\"C:\\Users\\ahmed\\OneDrive\\Desktop\\Python\\CIMTD\")\n",
    "\n",
    "# ── Base URL (constant across all year ranges)\n",
    "BASE_URL = \"https://www150.statcan.gc.ca/n1/pub/71-607-x/2021004/zip\"\n",
    "\n",
    "# ── File templates\n",
    "IMP_TMPL = \"CIMT-CICM_Imp_{year}.zip\"\n",
    "EXP_TMPL = \"CIMT-CICM_Tot_Exp_{year}.zip\"\n",
    "\n",
    "\n",
    "def download_file(url: str, dest: Path, force: bool = False):\n",
    "    \"\"\"Download a single file. Skips if already exists unless force=True.\"\"\"\n",
    "    if dest.exists() and not force:\n",
    "        print(f\"  [skip]  {dest.name}  (already downloaded)\")\n",
    "        return\n",
    "\n",
    "    print(f\"  [get]   {dest.name} ...\", end=\"  \", flush=True)\n",
    "    try:\n",
    "        r = requests.get(url, timeout=120, stream=True)\n",
    "        r.raise_for_status()\n",
    "        size = 0\n",
    "        with open(dest, \"wb\") as f:\n",
    "            for chunk in r.iter_content(chunk_size=1024 * 512):\n",
    "                f.write(chunk)\n",
    "                size += len(chunk)\n",
    "        print(f\"OK  ({size/1e6:.1f} MB)\")\n",
    "    except requests.HTTPError as e:\n",
    "        print(f\"HTTP {e.response.status_code} — skipping\")\n",
    "        if dest.exists():\n",
    "            dest.unlink()   # remove partial file\n",
    "    except Exception as e:\n",
    "        print(f\"ERROR: {e}\")\n",
    "        if dest.exists():\n",
    "            dest.unlink()\n",
    "\n",
    "    time.sleep(0.5)   # be polite to StatsCan servers\n",
    "\n",
    "\n",
    "def download_years(years: list, pause_between: float = 1.0):\n",
    "    \"\"\"Download imports + exports zips for a list of years.\"\"\"\n",
    "    for year in years:\n",
    "        for tmpl in (IMP_TMPL, EXP_TMPL):\n",
    "            fname = tmpl.format(year=year)\n",
    "            url   = f\"{BASE_URL}/{fname}\"\n",
    "            dest  = SAVE_DIR / fname\n",
    "            download_file(url, dest)\n",
    "        time.sleep(pause_between)\n",
    "\n",
    "\n",
    "# def download_block_a():\n",
    "#     \"\"\"\n",
    "#     BLOCK A — Historical static files (2012-2022).\n",
    "#     Run once. Comment out the call below after first run.\n",
    "#     \"\"\"\n",
    "#     print(\"\\n\" + \"=\" * 55)\n",
    "#     print(\"  BLOCK A: Historical files  2012-2022  (run once)\")\n",
    "#     print(\"=\" * 55)\n",
    "#     download_years(list(range(2012, 2023)))  # 2012 inclusive to 2022 inclusive\n",
    "\n",
    "\n",
    "def download_block_b():\n",
    "    \"\"\"\n",
    "    BLOCK B — Current year-range files (2023-2026).\n",
    "    Re-run monthly to pick up new data.\n",
    "    Files are overwritten each run so you always have the latest.\n",
    "    \"\"\"\n",
    "    print(\"\\n\" + \"=\" * 55)\n",
    "    print(\"  BLOCK B: Current files  2023-2026  (run monthly)\")\n",
    "    print(\"=\" * 55)\n",
    "    for year in range(2023, 2027):      # update upper bound if StatsCan adds 2027\n",
    "        for tmpl in (IMP_TMPL, EXP_TMPL):\n",
    "            fname = tmpl.format(year=year)\n",
    "            url   = f\"{BASE_URL}/{fname}\"\n",
    "            dest  = SAVE_DIR / fname\n",
    "            download_file(url, dest, force=True)   # force=True overwrites existing\n",
    "        time.sleep(1.0)\n",
    "\n",
    "\n",
    "if __name__ == \"__main__\":\n",
    "    SAVE_DIR.mkdir(parents=True, exist_ok=True)\n",
    "    print(f\"Save directory: {SAVE_DIR}\")\n",
    "\n",
    "    # ── First run: leave both lines active.\n",
    "    # ── After first run: comment out download_block_a().\n",
    "    # download_block_a()    # <-- comment out after first run\n",
    "    download_block_b()\n",
    "\n",
    "    print(\"\\nDone. Run cimt_build.py to generate the commodity workbooks.\")"
   ]
  },
